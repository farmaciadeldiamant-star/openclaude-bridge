# openclaude-bridge configuration — copy to .env and adjust as needed

# HTTP server
OPENCLAUDE_PORT=8788
OPENCLAUDE_HOST=127.0.0.1

# Model exposed to clients (OpenAI /v1/models advertises this ID)
OPENCLAUDE_MODEL=claude-opus-4-6

# "1" keeps a sticky workspace session (--continue). Unset/0 for fresh sessions.
OPENCLAUDE_CONTINUE=0

# Where Claude Code runs. Defaults to a tmp dir. Use a dedicated folder if you
# want a persistent CLAUDE.md / skills / memory for the bridge's own context.
# OPENCLAUDE_CWD=/path/to/bridge-workspace

# Per-turn timeout in ms
OPENCLAUDE_TIMEOUT_MS=180000

# Permission mode passed to `claude --permission-mode`
OPENCLAUDE_PERMS=bypassPermissions

# Optional explicit overrides (normally auto-detected)
# CLAUDE_CLI=/usr/lib/node_modules/@anthropic-ai/claude-code/cli.js
# NODE_BIN=/usr/bin/node
